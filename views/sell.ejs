<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sell on e-autopartstore</title>
    <link rel="stylesheet" href="../css_folder/sell.css">
    <link rel="stylesheet" href="../css_folder/scrollbar.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" 
       integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" 
       crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
  <header>
    <div class="top">
      <div class="logo">
        <a href="eas.homepage.html">
          <img src="../img_folder/Logo_2.png" alt="" width="250px" height="37px">
        </a>
      </div>
      <div class="others">
        <a href="cartpage.html"><i class="fa-solid fa-cart-shopping"></i></a> 
        <a href="profilepage.html"><i class="fa-solid fa-user"></i></a>
        <div class="toggle-bar" onclick="toggleDropdown()">
          <i class="fa-solid fa-bars" id="toggleButton"></i>
          <ul id="list" class="hidden">
            <li id="CatH">Categories</li>
            <li class="Catty">Toyota</li>
            <li class="Catty">Lexus</li>
            <li class="Catty">Honda</li>
            <li class="Catty">Audi</li>
            <li class="Catty">Acura</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="bottom">
      <div class="search">
          <span><i class="fa-solid fa-magnifying-glass"></i></span>
          <input type="text" placeholder="Search for products, categories and offers...">
          <button>
            search
          </button>
      </div>
  </header>
     <main>
        <div class="container">
          <form action="/sell-product" method="post">
            <h2>Upload Product</h2>
            <fieldset>
              <legend>Brand</legend>
              <select id="brand" onchange="updateModels()">
                <option disabled selected value="Select your brand" class="style">Select your brand</option>
                <option value="Audi">Audi</option>
                <option value="BMW">BMW</option>
                <option value="Chevrolet">Chevrolet</option>
                <option value="Ford">Ford</option>
                <option value="Honda">Honda</option>
                <option value="Lexus">Lexus</option>
                <option value="Mercedes Benz">Mercedes Benz</option>
                <option value="Nissan">Nissan</option>
                <option value="Peugeot">Peugeot</option>
                <option value="Suzuki">Suzuki</option>
                <option value="Toyota">Toyota</option>
                <option value="Volkswagen">Volkswagen</option>
              </select>
            </fieldset>
            <fieldset>
              <legend>Model</legend>
              <select id="model">
                <option disabled selected value="Model" class="style">Model</option>
                <!-- other options would be dynamically selected using JS -->
              </select>
            </fieldset>

            <section class="photo">
                <div class="upload-section">
                        <label for="photo" class="camera-label">
                            <i class="fa-solid fa-camera" style="font-size: 50px; color: var(--FCOLOR)"></i>
                        </label>
                        <input type="file" name="photo" id="photo" accept="image/*" capture="camera" style="display: none;" multiple>
                        
                        <label for="gallery" id="gall">
                            Choose from gallery
                        </label>
                        <input type="file" name="images" id="gallery" style="display: none;" multiple>
                </div>

                <div id="preview-section">
                  <!-- Image previews will be displayed here -->
                </div>
            </section>

            <div class="x-slide">
              <div class="text">
                Slide through to see more images
              </div>
              <div class="arr-anim">
                <div class="arr">🢂</div>
              </div>
            </div>

            <fieldset>
              <legend>Title</legend>
                  <select name="title" id="">
                      <option disabled selected value="Choose part" class="style">Choose part</option>
                      <option value="">Exhaust</option>
                      <option value="">Breakpads</option>
                      <option value="">Tyre</option>
                      <option value="">Gearbox</option>
                      <option value="">Windscreen</option>
                      <option value="">Headlights</option>
                      <!-- Add more items as you wish -->
                  </select>
            </fieldset>
            <fieldset id="desc">
              <legend>Description</legend>
              <textarea name="desccription" id="" placeholder="Give more details about product to be uploaded..." required></textarea>
            </fieldset>

            <select name="condition" id="cdt">
              <option disabled selected value="Condition">Condition</option>
              <option value="New">New</option>
              <option value="Nigerian Used">Nigerian Used</option>
              <option value="Tokunbo">Tokunbo</option>
            </select>

            <fieldset>
              <legend>Price</legend>
              <div id="amnt">
                  <span class="one">&#8358</span><span class="two"><input type="number" required></span>
              </div>
            </fieldset>
            <fieldset>
              <legend>Name</legend>
              <input type="text" placeholder="Enter your name" required>
            </fieldset>
            <fieldset>
              <legend>Whatsapp</legend>
                <input type="tel">
            </fieldset>
            <fieldset>
              <legend>Phone</legend>
              <input type="tel" required>
            </fieldset>

            <select name="location" id="lct">
              <option disabled selected value="Location">Location</option>
              <option value="">kjksdch</option>
              <option value="">hvbjvb</option>
              <option value="">dffffew</option>
              <option value="">defwwefewf</option>
              <option value="">efewfewf</option>
              <option value="">fweref</option>
              <option value="">wefewfefef</option>
            </select>

            <section class="bst">
              <p>Boost your product</p>
              <div class="no-bst">
                <article><span >No boost</span><span>Free</span></article>
              </div>

              <div class="yes-bst">
                <article><span>Boost Ad</span><span class="cl-prc">&#8358;9,748</span></article>
              </div>

              <div class="prm-bst">
                <article><span>Premium Boost</span><span class="cl-prc">&#8358;23,858</span></article>
              </div>
            </section>

            <p class="sell-btn"><button type="submit">Sell Now</button></p>

            <p>Terms and conditions, privacy policies</p>
          </form>
        </div>
     </main>
     <footer>
        <div class="mainft">
          <div class="socials">
            <p style="color: rgb(27, 151, 48);">Socials</p>
            <a href="">
              <p><i class="fa-brands fa-instagram"></i></p>
            </a>
            <a href="">
              <p><i class="fa-brands fa-facebook"></i></p>
            </a>
            <a href="">
              <p><i class="fa-brands fa-facebook-messenger"></i></p>
            </a>
            <a href="">
              <p><i class="fa-brands fa-x-twitter"></i></p>
            </a>
            <a href="">
              <p><i class="fa-brands fa-youtube"></i></p>
            </a>
            <a href="" style="text-decoration: none; font-size: 14px;">
              <p class="blog">Our Blog</p>
            </a>
          </div>
            <div class="contact">
              <p style="color: rgb(27, 151, 48);">Contact</p>
              <a href="">
                <i class="fa-brands fa-whatsapp"></i> +(234) 802 496 3039
              </a>
              <a href="">
                <i class="fa-solid fa-phone"></i> +(234) 814 6922 131
              </a>
            </div>
            <div class="about">
              <p style="color:  rgb(27, 151, 48);">About us</p>
              <p>About <span style="font-style: italic; color: aqua;"><a href="fdgfg" class="legal_pg" style="color: var(--BG-COLOR);">e-autopartstore</a></span></p>
              <p><a href="" class="legal_pg">Terms & Conditions</a></p>
              <p><a href="" class="legal_pg">Privacy Policy</a></p>
              <p><a href="" class="legal_pg">Billing Policy</a></p>
              <p><a href="" class="legal_pg">Cookie Policy</a></p>
              <p><a href="" class="legal_pg">Copyright Infringement Policy</a></p> 
            </div>
          </div> 
          <div class="ftft">
            <p><em>@2024 e-autopartstore</em></p>
          </div>
      </footer>

      <script src="/javaScript_folder/sell.js"></script>
</body>
</html>